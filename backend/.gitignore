# See https://docs.github.com/en/get-started/git-basics/ignoring-files for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
package-lock.json

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
/coverage
/coverage-*/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Uploads (images, files from multer)
uploads/
!uploads/.gitkeep

# MongoDB / Database
*.db
mongod.lock

# Temporary files
tmp/
temp/

